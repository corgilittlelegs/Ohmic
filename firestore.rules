rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidKey(key) {
      return key.matches('^WATT-[A-Z2-9]{4}-[A-Z2-9]{4}-[A-Z2-9]{4}$');
    }

    function isValidBill(bill) {
      return bill is map
        && bill.lastBillDate is string
        && bill.lastBillDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && bill.lastBillReading is number;
    }

    // Sanity-checks each reading's shape without an unbounded per-item loop
    // (Firestore rules can't iterate lists arbitrarily; size + spot checks
    // via .hasAll on the list's map elements are handled client-side by the
    // validated read path in lib/sync.ts — this cap bounds abuse cost).
    function isValidReadingsList(readings) {
      return readings is list && readings.size() <= 3000;
    }

    match /sync_sessions/{syncKey} {
      // Fetching a session requires being signed in (anonymous auth is fine)
      // AND knowing its exact, correctly-formatted sync key.
      allow get: if isSignedIn() && isValidKey(syncKey);
      // Never allow enumerating the collection.
      allow list: if false;

      allow create, update: if isSignedIn()
        && isValidKey(syncKey)
        && request.resource.data.keys().hasOnly(['bill', 'readings', 'updatedAt'])
        && isValidBill(request.resource.data.bill)
        && isValidReadingsList(request.resource.data.readings)
        && request.resource.data.updatedAt == request.time;

      allow delete: if isSignedIn() && isValidKey(syncKey);

      match /archives/{cycleId} {
        allow get: if isSignedIn() && isValidKey(syncKey);
        allow list: if isSignedIn() && isValidKey(syncKey);

        allow create, update: if isSignedIn()
          && isValidKey(syncKey)
          && request.resource.data.keys().hasOnly(['name', 'bill', 'readings', 'archivedAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 200
          && isValidBill(request.resource.data.bill)
          && isValidReadingsList(request.resource.data.readings)
          && request.resource.data.archivedAt is number;

        allow delete: if isSignedIn() && isValidKey(syncKey);
      }
    }
  }
}
